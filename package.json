{
  "name": "ivym",
  "version": "0.1.0",
  "description": "IvyM Music - Electron Desktop App",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "electron": "^43.0.0",
    "electron-store": "^11.0.2",
    "gsap": "^3.15.0",
    "motion": "^12.42.2",
    "ogl": "^1.0.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-scrambled-text": "^1.0.3",
    "split-type": "^0.3.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.ivym.music",
    "productName": "IvyM",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "server/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
